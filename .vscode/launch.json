{
  // Launch configurations працюють у devcontainer і використовують GDB з image окремого проєкту.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Launch Project",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/cppmiltech_bin", 
      "args": [], 
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}", 
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb", 
      "preLaunchTask": "CMake: configure and build", 
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}